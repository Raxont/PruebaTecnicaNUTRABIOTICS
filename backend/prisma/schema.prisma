// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  ADMIN
  DOCTOR
  PATIENT
}

enum PrescriptionStatus {
  PENDING
  CONSUMED
}

// Models
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  firstName     String?
  lastName      String?
  role          UserRole  @default(PATIENT)
  
  // Relations
  doctor        Doctor?
  patient       Patient?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([role])
  @@index([createdAt])
}

model Doctor {
  id            String    @id @default(cuid())
  userId        String    @unique
  specialty     String?   @unique
  
  // Relations
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  prescriptions Prescription[] @relation("doctor_prescriptions")
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([specialty])
  @@index([createdAt])
}

model Patient {
  id            String    @id @default(cuid())
  userId        String    @unique
  birthDate     DateTime?
  
  // Relations
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  prescriptions Prescription[] @relation("patient_prescriptions")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([createdAt])
}

model Prescription {
  id            String    @id @default(cuid())
  code          String    @unique @default(cuid())
  doctorId      String
  patientId     String?
  status        PrescriptionStatus @default(PENDING)
  notes         String?
  consumedAt    DateTime?
  patientEmail  String?   // Para creación de prescripción para paciente que no está en el sistema
  
  // Relations
  doctor        Doctor    @relation("doctor_prescriptions", fields: [doctorId], references: [id], onDelete: Cascade)
  patient       Patient?  @relation("patient_prescriptions", fields: [patientId], references: [id], onDelete: Cascade)
  items         PrescriptionItem[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([doctorId])
  @@index([patientId])
}

model PrescriptionItem {
  id            String    @id @default(cuid())
  prescriptionId String
  prescription  Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  
  name          String    // Nombre del medicamento
  dosage        String    // e.g., "500mg"
  quantity      Int       // Cantidad de dosis
  instructions  String?   // Indicaciones

  @@index([prescriptionId])
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
